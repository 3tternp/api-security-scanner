# ─────────────────────────────────────────────────────────────────────────────
# API Security Scanner — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before starting the app.
# NEVER commit .env to version control.
#
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | production

# ── JWT (required) ────────────────────────────────────────────────────────────
# Must be a random 64-char hex string. Do NOT use the example value.
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_python_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
POSTGRES_USER=apiscanner
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_DB_PASSWORD
POSTGRES_SERVER=db               # use "localhost" for local dev without Docker
POSTGRES_PORT=5432
POSTGRES_DB=apiscanner

# ── CORS origins (comma-separated list as JSON array) ─────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]

# ── First-run admin bootstrap (optional) ─────────────────────────────────────
# Set these ONLY for the first boot to auto-create the admin account.
# Remove or unset them after the first successful start.
#
# Password must be ≥12 chars and include upper, lower, digit, special char.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_ADMIN_PASSWORD

# ── Account lockout policy ────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
MIN_PASSWORD_LENGTH=12
